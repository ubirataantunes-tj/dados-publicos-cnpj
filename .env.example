# ===================================================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# ===================================================================

# Host do banco PostgreSQL
DB_HOST=localhost

# Porta do banco PostgreSQL
DB_PORT=5432

# Nome do banco de dados
DB_NAME=receita_cnpj

# Usuário do banco
DB_USER=postgres

# Senha do banco
DB_PASSWORD=sua_senha_aqui

# Modo SSL para conexão com o banco (disable, allow, prefer, require)
# Use 'disable' para desenvolvimento local/docker, 'require' para produção
DB_SSL_MODE=prefer

# ===================================================================
# CONFIGURAÇÕES DO POOL DE CONEXÕES
# ===================================================================

# Tamanho mínimo do pool de conexões
DB_POOL_MIN_SIZE=2

# Tamanho máximo do pool de conexões
DB_POOL_MAX_SIZE=10

# Timeout para comandos SQL (em segundos)
DB_COMMAND_TIMEOUT=3600

# Timeout para aquisição de conexão do pool (em segundos)
DB_POOL_ACQUIRE_TIMEOUT=10

# Timeout para conexão com o banco (em segundos)
DB_CONNECT_TIMEOUT=30

# ===================================================================
# CONFIGURAÇÕES DE TCP KEEPALIVE
# ===================================================================

# Tempo idle antes de enviar keepalive (em segundos)
TCP_KEEPALIVE_IDLE=30

# Intervalo entre keepalive probes (em segundos)
TCP_KEEPALIVE_INTERVAL=10

# Número de keepalive probes antes de desistir
TCP_KEEPALIVE_COUNT=3

# ===================================================================
# CONFIGURAÇÕES DE REDE / DOWNLOAD
# ===================================================================

# URL base dos dados da Receita Federal
RECEITA_FEDERAL_BASE_URL=https://arquivos.receitafederal.gov.br/public.php/dav/files/gn672Ad4CF8N6TK

# URL de compartilhamento para obter token
RECEITA_FEDERAL_SHARE_URL=https://arquivos.receitafederal.gov.br/index.php/s/gn672Ad4CF8N6TK

# Timeout de leitura HTTP (em segundos)
HTTP_TIMEOUT_READ=60.0

# Timeout de conexão HTTP (em segundos)
HTTP_TIMEOUT_CONNECT=30.0

# Timeout de leitura para downloads (em segundos)
DOWNLOAD_TIMEOUT_READ=120.0

# Timeout de conexão para downloads (em segundos)
DOWNLOAD_TIMEOUT_CONNECT=60.0

# Timeout para detecção de stall no download (em segundos)
DOWNLOAD_STALL_TIMEOUT=30

# Tamanho do chunk para download (em bytes, padrão 2MB)
DOWNLOAD_CHUNK_SIZE=2097152

# Número máximo de tentativas para requests HTTP
MAX_RETRIES=5

# Número máximo de falhas consecutivas no download
MAX_CONSECUTIVE_DOWNLOAD_FAILURES=5

# Máximo de conexões keepalive simultâneas
HTTP_MAX_KEEPALIVE_CONNECTIONS=1

# Máximo de conexões HTTP simultâneas
HTTP_MAX_CONNECTIONS=2

# ===================================================================
# CONFIGURAÇÕES DE PROCESSAMENTO
# ===================================================================

# Tamanho do chunk para processamento pandas (linhas por chunk)
DATA_CHUNK_SIZE=500000

# Número de workers para extração paralela de ZIP
EXTRACT_MAX_WORKERS=4

# ===================================================================
# CONFIGURAÇÕES DE TIMEOUT DO ETL
# ===================================================================

# Timeout para criação de índices (em segundos, padrão 30 min)
ETL_INDEX_TIMEOUT=1800

# Timeout para operações COPY (em segundos, padrão 15 min)
ETL_COPY_TIMEOUT=900

# ===================================================================
# CONFIGURAÇÕES DE ARMAZENAMENTO
# ===================================================================

# Diretório para downloads dos arquivos ZIP
OUTPUT_FILES_PATH=./dados/downloads

# Diretório para arquivos CSV extraídos
EXTRACTED_FILES_PATH=./dados/extracted

# ===================================================================
# INSTRUÇÕES DE USO
# ===================================================================

# 1. Copie este arquivo para .env:
#    cp .env.example .env
#
# 2. Edite o arquivo .env com suas configurações
#
# 3. Certifique-se de que o PostgreSQL está rodando:
#    sudo systemctl start postgresql
#
# 4. Crie o banco de dados:
#    createdb -U postgres receita_cnpj
#
# 5. Execute o ETL:
#    uv run src/etl/ETL_dados_publicos_empresas.py
#
# ===================================================================
# VARIÁVEIS OBRIGATÓRIAS PARA FUNCIONAMENTO
# ===================================================================
#
# As seguintes variáveis são obrigatórias e devem ser configuradas:
# - DB_PASSWORD: Senha do banco PostgreSQL
# - OUTPUT_FILES_PATH: Diretório onde arquivos ZIP serão baixados
# - EXTRACTED_FILES_PATH: Diretório onde arquivos CSV serão extraídos
#
# ===================================================================

